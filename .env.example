NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/zatpat_crm

# JWT
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookies
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS
CLIENT_ORIGIN=http://localhost:5173

# IP whitelist enforcement (set to false in dev)
IP_WHITELIST_ENABLED=false

# Seed user (used by `npm run seed`)
SEED_SUPERADMIN_NAME=Super Admin
SEED_SUPERADMIN_EMAIL=admin@zatpatloans.local
SEED_SUPERADMIN_PHONE=9999999999
SEED_SUPERADMIN_PASSWORD=ChangeMe@123
